generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id                Int         @id @default(autoincrement())
  name              String
  email             String      @unique
  passwordHash      String
  resetToken        String?
  resetTokenExpires DateTime?
  foundItems        FoundItem[]
  createdAt         DateTime    @default(now())
}

model LostReport {
  id            Int            @id @default(autoincrement())
  name          String
  reporterType  String         @default("Mahasiswa")
  nim           String?
  nonStudentId  String?
  email         String
  phone         String
  category      String
  description   String
  lostDate      DateTime
  status        String         @default("Hilang")
  createdAt     DateTime       @default(now())
  matchings     Matching[]
  notifications Notification[]
}

model FoundItem {
  id            Int            @id @default(autoincrement())
  adminId       Int?
  admin         Admin?         @relation(fields: [adminId], references: [id])
  name          String
  brand         String?
  color         String?
  category      String
  locationFound String
  foundDate     DateTime
  description   String?
  photoUrl      String?
  status        String         @default("Ditemukan")
  claimedByName String?
  claimedAt     DateTime?
  returnedAt    DateTime?
  createdAt     DateTime       @default(now())
  notifications Notification[]
  matchings     Matching[]
}

model Notification {
  id           Int         @id @default(autoincrement())
  foundItemId  Int?
  foundItem    FoundItem?  @relation(fields: [foundItemId], references: [id], onDelete: Cascade)
  lostReportId Int?
  lostReport   LostReport? @relation(fields: [lostReportId], references: [id], onDelete: Cascade)
  message      String
  read         Boolean     @default(false)
  sentAt       DateTime    @default(now())
}

model Matching {
  id             Int        @id @default(autoincrement())
  lostReportId   Int
  foundItemId    Int
  lostReport     LostReport @relation(fields: [lostReportId], references: [id], onDelete: Cascade)
  foundItem      FoundItem  @relation(fields: [foundItemId], references: [id], onDelete: Cascade)
  matchingScore  Float      @default(0.0)
  matchBreakdown String?    @db.Text
  matchedAt      DateTime   @default(now())
  isConfirmed    Boolean    @default(false)
}
